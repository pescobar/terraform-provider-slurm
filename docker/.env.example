# Copy to .env and adjust before running docker compose.
# The SLURM_VERSION value is used both as the image tag pulled from GHCR
# and as the build arg when building locally.

SLURM_VERSION=25.11.4

# MariaDB credentials (defaults match the image defaults)
#MYSQL_DATABASE=slurm_acct_db
#MYSQL_USER=slurm
#MYSQL_PASSWORD=password
